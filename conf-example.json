{
  "version": "1.0",
  "spec": {
    "defaults": {
      "deploy_target": "target",
      "llm_provider": "deepseek"
    },
    "runner": {
      "exec_env": "github_actions",
      "tz": "Asia/Shanghai"
    },
    "sites": [
      {
        "meta": {
          "name": "zola",
          "desc": "Zola文档翻译"
        },
        "source": {
          "git": "https://github.com/getzola/zola.git",
          "dir": "docs"
        },
        "target": {
          "git": "https://github.com/czy-29/docs.29bot.com.git",
          "dir": "zola"
        },
        "framework": {
          "preset": "zola"
        },
        "translate": {
          "exts": ["md", "markdown"]
        }
      },
      {
        "meta": {
          "name": "mdbook",
          "desc": "mdBook文档翻译"
        },
        "source": {
          "git": "https://github.com/rust-lang/mdBook.git",
          "dir": "guide"
        },
        "target": {
          "git": "https://github.com/czy-29/docs.29bot.com.git",
          "dir": "mdbook"
        },
        "framework": {
          "preset": "mdbook"
        },
        "translate": {
          "exts": ["md", "markdown"]
        }
      }
    ]
  }
}
