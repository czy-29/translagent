{
  "version": "1.0",
  "spec": {
    "defaults": {
      "translate": {
        "provider": "deepseek"
      },
      "deploy": {
        "target": "target"
      }
    },
    "runner": {
      "exec_env": "github_actions",
      "tz": "Asia/Shanghai"
    },
    "sites": {
      "zola": {
        "meta": {
          "desc": "Zola文档翻译"
        },
        "source": {
          "git": "https://github.com/getzola/zola.git",
          "dir": "docs"
        },
        "target": {
          "git": "https://github.com/czy-29/docs.29bot.com.git",
          "dir": "zola"
        },
        "framework": {
          "preset": "zola"
        },
        "translate": {
          "exts": ["md", "markdown"]
        }
      },
      "mdbook": {
        "meta": {
          "desc": "mdBook文档翻译"
        },
        "source": {
          "git": "https://github.com/rust-lang/mdBook.git",
          "dir": "guide"
        },
        "target": {
          "git": "https://github.com/czy-29/docs.29bot.com.git",
          "dir": "mdbook"
        },
        "framework": {
          "preset": "mdbook"
        },
        "translate": {
          "exts": ["md", "markdown"]
        }
      }
    }
  }
}
